# Python
__pycache__/
*.py[cod]
*.egg-info/
*.egg
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Virtual envs
.venv/
venv/
env/
.python-version

# OS / IDE
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~

# Data — raw and processed datasets are fetched locally, not redistributed
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep

# Result caches — only summary CSVs are tracked; per-cell caches are local
results/**/cache/
results/**/cache_*/
results/runs/

# LaTeX build artefacts (if you compile a local copy of the thesis)
*.aux
*.log
*.toc
*.lof
*.lot
*.out
*.bbl
*.blg
*.synctex.gz
*.fdb_latexmk
*.fls
